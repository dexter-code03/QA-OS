# QA OS Platform — Environment Configuration
# Copy this file to .env and fill in the values.

# ── AI (Gemini) ──────────────────────────────────────────────────────
# Google Gemini API key for AI-powered step generation and fixes
AI_API_KEY=
# Model name (default: gemini-2.5-flash)
AI_MODEL=gemini-2.5-flash

# ── Appium ───────────────────────────────────────────────────────────
# Appium server host and port
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# ── Confluence (optional) ────────────────────────────────────────────
# Atlassian Confluence integration for syncing test documentation
CONFLUENCE_URL=
CONFLUENCE_USER=
CONFLUENCE_TOKEN=
CONFLUENCE_SPACE_KEY=

# ── Figma (optional) ─────────────────────────────────────────────────
# Figma access token for component name extraction
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=
